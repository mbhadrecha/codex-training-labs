{
  "name": "todo-backend",
  "version": "1.0.0",
  "description": "A lightweight Node/Express API for persisting ToDo tasks.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --test --test-concurrency=1 tests/**/*.test.js",
    "coverage": "c8 --all --include=src/index.js --reporter=text --reporter=lcov --reporter=json-summary --report-dir coverage node --test --test-concurrency=1 tests/**/*.test.js"
  },
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "nodemon": "^2.0.22"
  }
}
